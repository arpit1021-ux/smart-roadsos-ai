# Smart RoadSos AI - Environment Configuration
# Copy this file to .env and fill in the values

# Backend Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://admin:password@mongodb:27017/roadsos?authSource=admin
# For local development without Docker:
# MONGODB_URI=mongodb://localhost:27017/roadsos

# JWT Authentication (change this in production!)
JWT_SECRET=roadsos_super_secure_key_2026_hackathon_project
JWT_EXPIRE=7d

# Google Maps API (Required - get from Google Cloud Console)
# Enable: Maps JavaScript API, Places API, Directions API, Geocoding API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Twilio SMS (Optional - for SMS alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# AI Service
AI_SERVICE_URL=http://localhost:5001
# When using Docker:
# AI_SERVICE_URL=http://ai-module:5001

# Frontend Configuration (frontend/.env)
VITE_API_URL=http://localhost:5000/api
VITE_GOOGLE_MAPS_KEY=your-google-maps-api-key-here
VITE_WS_URL=http://localhost:5000
